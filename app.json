{
  "expo": {
    "name": "Zenifi",
    "slug": "zenifi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "zenifi",
    "backgroundColor": "#F4F9F4",
    "primaryColor": "#0E2F2F",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F4F9F4"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.justitdo.zenifi"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0E2F2F",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.justitdo.zenifi",
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      "expo-font",
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Aplikacja potrzebuje Face ID, żeby szybko odblokować dostęp do finansów."
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Aplikacja potrzebuje aparatu do zrobienia zdjęcia paragonu.",
          "photosPermission": "Aplikacja potrzebuje dostępu do zdjęć, żeby wybrać screen płatności albo obraz paragonu."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "869f10a2-5618-4a50-9453-572d503268e7"
      }
    },
    "owner": "justitdo"
  }
}
